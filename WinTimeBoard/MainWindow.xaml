<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WinTimeBoard.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinTimeBoard"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WinTimeBoard">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="TimeText" FontSize="96" FontWeight="Bold" />
                <TextBlock x:Name="DateText" FontSize="36" Margin="0,8,0,0" />
            </StackPanel>
        </Grid>

        <!-- Bottom-left button group (stacked horizontally to the left) -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12" Spacing="8">
            <Button x:Name="MenuButton"
                    FontFamily="Segoe Fluent Icons"
                    Content="&#xE700;"
                    Width="40"
                    Height="40">
                <Button.Flyout>
                    <Flyout Placement="Top" x:Name="MenuFlyout">
                        <StackPanel  Padding="8">
                            <!-- 关于 -->
                            <TextBlock Text="关于" FontSize="28" FontWeight="Bold" Margin="0,0,0,8"/>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock x:Name="AppNameText" Text="🕒 WinTimeBoard BETA" FontFamily="Segoe UI SemiBold" FontSize="24"/>
                                <!--<TextBlock x:Name="AppVersionText" Text="Ver 1.0.0" Margin="0,4,0,0"/>-->
                                <TextBlock Text="Copyright © 2025 Shihao Shen. All rights reserved." Margin="0,8,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>

            <Button x:Name="ExitButton"
                    Click="ExitButton_Click"
                    FontFamily="Segoe Fluent Icons"
                    Content="&#xE711;"
                    Width="40"
                    Height="40"
                    />

            <Button x:Name="HideButton"
                    Click="HideButton_Click"
                    FontFamily="Segoe Fluent Icons"
                    Content="&#xED1A;"
                    Width="40"
                    Height="40"
                    />
        </StackPanel>
    </Grid>
</Window>
