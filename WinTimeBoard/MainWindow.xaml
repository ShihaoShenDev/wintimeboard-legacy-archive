<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WinTimeBoard.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinTimeBoard"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WinTimeBoard">

    <!--
        随便说说：
        这里的很多代码都是使用 Qoder 的 Quest 模式生成的，代码质量不错[doge]
        同时此项目参考了 WinUI 3 Gallery 的一些示例代码
    -->
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
        <!-- 回退背景代码（好像没用了） -->
    </Window.SystemBackdrop>

    <Grid>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="TimeText" FontSize="96" FontWeight="Bold" />
                <TextBlock x:Name="DateText" FontSize="36" Margin="0,8,0,0" />
            </StackPanel>
        </Grid>

        <!-- Bottom-left button group (stacked horizontally to the left) -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12" Spacing="8">
            <DropDownButton x:Name="MenuButton" 
                    Width="120"
                    Height="64">
                <StackPanel Orientation="Horizontal">
                    <FontIcon Glyph="&#xE700;"/>
                    <TextBlock Text=" 菜单"/>
                </StackPanel>
                <DropDownButton.Flyout>
                    <Flyout Placement="Top" x:Name="MenuFlyout">
                        <ScrollViewer MaxHeight="800" VerticalScrollBarVisibility="Auto">
                            <StackPanel Padding="12" Spacing="16" MinWidth="280">
                                
                                <!-- 外观设置 -->
                                <StackPanel>
                                    <TextBlock Text="外观设置" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>

                                    <!-- 这里有奇奇怪怪的问题，暂时把这些选项给禁用了（亮暗色先开着吧，学校里要用） -->

                                    <!-- 主题模式 -->
                                    <StackPanel Margin="8,0,0,0" Spacing="4">
                                        <TextBlock Text="主题模式" FontSize="14" FontWeight="Medium" Margin="0,0,0,4"/>
                                        <RadioButtons x:Name="ThemeRadioButtons" SelectionChanged="ThemeRadioButtons_SelectionChanged">
                                            <RadioButton Content="跟随系统" Tag="FollowSystem" IsChecked="True"/>
                                            <RadioButton Content="浅色" Tag="Light" IsEnabled="False"/>
                                            <RadioButton Content="深色" Tag="Dark"/>
                                        </RadioButtons>
                                    </StackPanel>
                                    
                                    <!-- 背景材质 -->
                                    <StackPanel Margin="8,0,0,0" Spacing="4">
                                        <TextBlock Text="背景材质" FontSize="14" FontWeight="Medium" Margin="0,8,0,4"/>
                                        <RadioButtons x:Name="MaterialRadioButtons" SelectionChanged="MaterialRadioButtons_SelectionChanged">
                                            <RadioButton Content="云母" Tag="Mica" IsChecked="True"/>
                                            <RadioButton Content="亚克力" Tag="Acrylic"/>
                                            <RadioButton Content="Tabbed" Tag="MicaAlt"/>
                                            <RadioButton Content="薄亚克力" Tag="AcrylicThin" IsEnabled="False"/>
                                            <RadioButton Content="无" Tag="None"/>
                                        </RadioButtons>
                                    </StackPanel>
                                </StackPanel>
                                
                                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="-4,0"/>
                                
                                <!-- 时间显示设置 -->
                                <StackPanel>
                                    <TextBlock Text="时间显示" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    
                                    <StackPanel Margin="8,0,0,0" Spacing="8">
                                        <Button x:Name="TimeFormatButton" 
                                                Content="时间格式设置" 
                                                HorizontalAlignment="Stretch"
                                                Click="TimeFormatButton_Click"/>
                                        <Button x:Name="DateFormatButton" 
                                                Content="日期格式设置" 
                                                HorizontalAlignment="Stretch"
                                                Click="DateFormatButton_Click"/>
                                        <Button x:Name="FontSettingsButton" 
                                                Content="字体设置" 
                                                HorizontalAlignment="Stretch"
                                                Click="FontSettingsButton_Click"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="-4,0"/>
                                
                                <!-- 关于 -->
                                <StackPanel>
                                    <TextBlock Text="关于" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <StackPanel Margin="8,0,0,0">
                                        <TextBlock x:Name="AppNameText" Text="WinTimeBoard 1.2"/>
                                        <TextBlock Text="Copyright © 2025 Shihao Shen. All rights reserved." 
                                                  Margin="0,4,0,0" 
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                                
                            </StackPanel>
                        </ScrollViewer>
                    </Flyout>
                </DropDownButton.Flyout>
            </DropDownButton>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="12"  Spacing="8">
            <!--
                TODO: 增加启动器功能
                推荐大家用 ReSharper for VS2026 修改代码，我这里很多代码都是用它按 Tab 按出来的（比如上面一行）（JB快付我广告费[doge]）
            -->
            <Button x:Name="LauncherButton" 
                    IsEnabled="False"
                    Style="{StaticResource AccentButtonStyle}"
                    Width="64"
                    Height="64">
                <Button.Content>
                    <FontIcon Glyph="&#xE8FC;"/>
                </Button.Content>
                <Button.Flyout>
                    <Flyout Placement="Top">
                        <ScrollViewer MaxHeight="800" VerticalScrollBarVisibility="Auto">
                            <StackPanel Padding="12" Spacing="16" MinWidth="280">
                                <!-- 关于 -->
                                <StackPanel>
                                    <TextBlock Text="关于" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <StackPanel Margin="8,0,0,0">
                                        <TextBlock Text="WinTimeBoard 1.1"/>
                                        <TextBlock Text="Copyright © 2025 Shihao Shen. All rights reserved." 
                          Margin="0,4,0,0" 
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12" Spacing="8">
            <Button x:Name="HideButton"
                    Style="{StaticResource SubtleButtonStyle}"
                    Click="HideButton_Click"
                    Width="96"
                    Height="64">
                <StackPanel Orientation="Horizontal">
                    <FontIcon Glyph="&#xED1A;"/>
                    <TextBlock Text=" 隐藏"/>
                </StackPanel>
            </Button>

            <Button x:Name="ExitButton"
                    Style="{StaticResource SubtleButtonStyle}"
                    Click="ExitButton_Click"
                    Width="96"
                    Height="64">
                <StackPanel Orientation="Horizontal">
                    <FontIcon Glyph="&#xE711;"/>
                    <TextBlock Text=" 退出"/>
                </StackPanel>
                </Button>
        </StackPanel>
    </Grid>
</Window>
